# Privy Configuration (for EVM wallets and authentication)
VITE_APP_ID=your_privy_app_id
VITE_CLIENT_ID=your_privy_client_id

# Reown AppKit Configuration (for Solana wallet connections)
# Get your project ID from: https://dashboard.reown.com
VITE_REOWN_PROJECT_ID=your_reown_project_id
# Or use this fallback if using same project ID
# VITE_PROJECT_ID=your_project_id

# Solana RPC Configuration
# For devnet (testing)
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# For mainnet (production) - uncomment when ready
# VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# For custom RPC (recommended for production)
# VITE_SOLANA_RPC_URL=https://your-rpc-provider.com/api-key
