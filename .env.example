# Privy Configuration
VITE_PRIVY_APP_ID=your_privy_app_id

# Solana RPC Configuration
VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key
VITE_SOLANA_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=your_helius_api_key

# For devnet testing
# VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
# VITE_SOLANA_WSS_URL=wss://api.devnet.solana.com

# Server Secret (DO NOT expose in frontend - for backend only)
APP_SECRET=your_app_secret

# API Configuration
VITE_API_BASE_URL=base_url

# Share URL Configuration (used for /share/* links for social previews)
# Set this to the backend/domain that serves crawler-friendly share pages.
VITE_SHARE_BASE_URL=https://obverse.onrender.com
